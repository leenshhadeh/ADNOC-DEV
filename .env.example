# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# Base URL for all API requests (no trailing slash)
VITE_API_BASE_URL=https://api.example.com/v1

# Azure AD tenant & app registration IDs
VITE_TENANT_ID=
VITE_CLIENT_ID=
VITE_BACKEND_CLIENT_ID=

# Set to "true" to bypass Azure MSAL and use a mock user (development only).
# This flag is ignored in production builds.
VITE_MOCK_AUTH=false
