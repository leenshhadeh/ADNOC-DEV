# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# Set to "true" to bypass Azure MSAL and use a mock user (development only).
# This flag is ignored in production builds.
VITE_MOCK_AUTH=false

# ─── Runtime Config (Kubernetes ConfigMap) ────────────────────────────────────
# All values below are injected at RUNTIME via a ConfigMap mounted as
# /usr/share/nginx/html/config.json — no image rebuild required when they change.
#
# For local development, edit public/config.json directly.
#
# Keys expected in config.json:
#   API_BASE_URL        — Base URL for all API requests (no trailing slash)
#   TENANT_ID           — Azure AD tenant ID
#   CLIENT_ID           — Azure AD app registration client ID
#   BACKEND_CLIENT_ID   — Azure AD backend app registration ID (for token scopes)
#   BPA_GUIDELINES_URL  — URL to the BPA guidelines document/page
#   SERVICENOW_URL      — ServiceNow portal link
